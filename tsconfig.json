{
	"include": ["./src", "**/*.ts", "**/*.tsx", "eslint.config.js", "vite.config.js"],

	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"jsx": "react-jsx",
		"types": ["node", "vite/client"],
		"lib": ["ES2024", "DOM", "DOM.Iterable"],

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,

		/* Linting */
		"strict": true,
		"skipLibCheck": true,
		"rootDir": ".",
		"paths": {
			"~/*": ["./*"],
			"@/*": ["./src/*"]
		}
	}
}
